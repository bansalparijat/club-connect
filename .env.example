# Database (Supabase)
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# JWT
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"

# Twilio (OTP)
TWILIO_ACCOUNT_SID="ACxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxx"

# WhatsApp
WHATSAPP_PROVIDER="meta"  # or "twilio"
META_WHATSAPP_TOKEN="your-meta-token"
META_PHONE_NUMBER_ID="your-phone-number-id"
# TWILIO_WHATSAPP_FROM="+14155238886"  # for twilio provider

# AWS
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
SQS_QUEUE_URL="https://sqs.ap-south-1.amazonaws.com/123456789/club-connect-notifications-staging"
# AWS_SECRETS_ARN="arn:aws:secretsmanager:ap-south-1:..." # production only

# App
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"

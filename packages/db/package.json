{
  "name": "@club-connect/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../apps/api/.env.local -- prisma migrate dev",
    "db:push": "dotenv -e ../../apps/api/.env.local -- prisma db push",
    "db:reset": "dotenv -e ../../apps/api/.env.local -- prisma migrate reset",
    "seed": "dotenv -e ../../apps/api/.env.local -- tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.0",
    "prisma": "^5.15.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
